# ============================================================
# CodeSaaS Backend — copy this to .env and fill in your keys
# ============================================================

# --- LLM Provider ---
OPENAI_API_KEY=your_key_here
OPENAI_API_BASE=https://api.blackbox.ai/v1
MODEL_NAME=blackboxai/google/gemini-3.1-pro-preview
MODEL_SUPERVISOR=blackboxai/anthropic/claude-opus-4.5
MODEL_FRONTEND=blackboxai/google/gemini-3.1-pro-preview
MODEL_BACKEND=blackboxai/openai/gpt-4.1-mini
MODEL_DATABASE=blackboxai/openai/gpt-4.1-mini
MODEL_DEVOPS=blackboxai/google/gemini-2.5-flash
MODEL_INTEGRATION=blackboxai/openai/gpt-4.1-mini
MODEL_QA=blackboxai/anthropic/claude-sonnet-4.5

# --- E2B Sandbox ---
E2B_API_KEY=your_e2b_key_here
E2B_TEMPLATE=

# --- Gemini API (for AI image generation in sandboxed apps) ---
GEMINI_API_KEY=

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# --- CORS (comma-separated allowed origins) ---
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
